# Base URL of the CRM backend. The site reads the ACTIVE WhatsApp channel from
# it at build time (GET /public/whatsapp/channel), so the CRM stays the single
# source of truth for the number every CTA opens. Change the channel in the admin
# panel and the site follows — no redeploy, no config edit here.
CRM_API_URL=

# Local-dev escape hatch ONLY, for when the CRM isn't reachable.
# E.164 digits, no "+", e.g. 923350001111. Production should use CRM_API_URL.
NEXT_PUBLIC_WA_NUMBER=
